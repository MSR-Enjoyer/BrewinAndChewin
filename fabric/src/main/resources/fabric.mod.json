{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${minecraft_version}-${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${fabric_mod_authors}"
  ],
  "contact": {
    "homepage": "${modrinth_page}",
    "issues": "https://github.com/${sources}/issues",
    "sources": "https://github.com/${sources}"
  },
  "license": "${mod_license}",
  "icon": "assets/brewinandchewin/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "umpaz.brewinandchewin.fabric.BrewinAndChewinFabric"
    ],
    "client": [
      "umpaz.brewinandchewin.fabric.client.BrewinAndChewinFabricClient"
    ],
    "preLaunch": [
      "umpaz.brewinandchewin.fabric.BrewinAndChewinFabricPre"
    ],
    "mm:early_risers": [
      "umpaz.brewinandchewin.fabric.BrewinAndChewinASM"
    ],
    "jei_mod_plugin": [
      "umpaz.brewinandchewin.integration.jei.JEIPlugin"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json",
    "${mod_id}.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": "${fabric_loader_range}",
    "fabric-api": "*",
    "minecraft": "${fabric_minecraft_version_range}",
    "java": ">=${java_version}",
    "farmersdelight": "${farmers_delight_refabricated_range}",
    "greenhouseconfig": "${fabric_greenhouse_config_range}"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.curseforge": "${curseforge_page}",
        "modmenu.modrinth": "${modrinth_page}",
        "modmenu.github_releases": "https://github.com/${sources}/releases"
      }
    }
  }
}